<UserControl x:Class="BetterGenshinImpact.View.Pages.AiChatPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behavior="clr-namespace:BetterGenshinImpact.View.Behavior"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:BetterGenshinImpact.Model.Ai"
             xmlns:pages="clr-namespace:BetterGenshinImpact.ViewModel.Pages"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             d:DataContext="{d:DesignInstance Type=pages:AiChatViewModel}"
             ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             FontFamily="{StaticResource TextThemeFontFamily}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type models:AiChatMessage}">
            <Grid x:Name="ItemRoot" Margin="0,6">
                <Border x:Name="Bubble"
                        Padding="10"
                        Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Left"
                        MaxWidth="520">
                    <StackPanel>
                        <ui:TextBlock FontTypography="Caption"
                                      Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                      Text="{Binding DisplayRole}" />
                        <TextBlock x:Name="PlainContent"
                                   Margin="0,4,0,0"
                                   Text="{Binding Content}"
                                   TextWrapping="Wrap" />
                        <RichTextBox x:Name="MarkdownContent"
                                     Margin="0,4,0,0"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     behavior:RichTextBoxMarkdownBehavior.Markdown="{Binding Content}"
                                     FocusVisualStyle="{x:Null}"
                                     HorizontalScrollBarVisibility="Disabled"
                                     IsDocumentEnabled="True"
                                     IsReadOnly="True"
                                     Padding="0"
                                     VerticalScrollBarVisibility="Disabled"
                                     Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsAssistant}" Value="True">
                    <Setter TargetName="PlainContent" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="MarkdownContent" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsUser}" Value="True">
                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right" />
                    <Setter TargetName="Bubble" Property="Background" Value="{ui:ThemeResource ControlFillColorSecondaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMcp}" Value="True">
                    <Setter TargetName="Bubble" Property="Background" Value="{ui:ThemeResource ControlFillColorTertiaryBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSystem}" Value="True">
                    <Setter TargetName="Bubble" Property="Background" Value="{ui:ThemeResource ControlFillColorTertiaryBrush}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMcp}" Value="True" />
                        <Condition Binding="{Binding DataContext.Config.ShowMcpVisualizationOutput, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="ItemRoot" Property="Visibility" Value="Collapsed" />
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="8,0,8,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,8,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <ui:TextBlock FontTypography="Title" Text="AI 问答" />
                <ui:TextBlock Margin="0,2,0,0"
                              Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                              Text="{Binding StatusText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ui:Button Margin="0,0,8,0"
                           Command="{Binding ClearChatHistoryCommand}"
                           Content="清空记录"
                           Icon="{ui:SymbolIcon Delete24}" />
                <ui:Button Command="{Binding OpenSettingsCommand}"
                           Content="设置"
                           Icon="{ui:SymbolIcon Settings24}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,8"
                Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl Margin="12"
                              ItemsSource="{Binding Messages}" />
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        x:Name="InputTextBox"
                        MinHeight="72"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        PreviewKeyDown="InputTextBox_OnPreviewKeyDown"
                        Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="输入问题，回车发送（Shift+回车换行）" />
            <ui:Button Grid.Column="1"
                       Margin="8,0,0,0"
                       MinWidth="88"
                       VerticalAlignment="Bottom"
                       Command="{Binding SendMessageCommand}"
                       Content="发送" />
        </Grid>
    </Grid>
</UserControl>
