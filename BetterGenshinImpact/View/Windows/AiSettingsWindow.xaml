<ui:FluentWindow x:Class="BetterGenshinImpact.View.Windows.AiSettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="AI 设置"
                 Width="640"
                 Height="720"
                 MinWidth="520"
                 MinHeight="520"
                 WindowBackdropType="Auto"
                 WindowCornerPreference="Round"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 FontFamily="{DynamicResource TextThemeFontFamily}"
                 mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="AI 设置"
                     Icon="pack://application:,,,/Resources/Images/logo.png" />

        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <ui:CardExpander IsExpanded="True"
                                     ContentPadding="12"
                                     Icon="{ui:SymbolIcon Settings24}">
                        <ui:CardExpander.Header>
                            <StackPanel>
                                <ui:TextBlock FontTypography="BodyStrong" Text="AI 接口" />
                                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                              Text="OpenAI Chat Completions (/v1/chat/completions)，Base URL 会自动补全 /v1。" />
                            </StackPanel>
                        </ui:CardExpander.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:TextBlock Grid.Row="0"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="Base URL" />
                            <ui:TextBox Grid.Row="0"
                                        Grid.Column="1"
                                        Margin="0,0,0,8"
                                        Text="{Binding Config.BaseUrl, Mode=TwoWay}"
                                        PlaceholderText="https://api.openai.com/v1" />

                            <ui:TextBlock Grid.Row="1"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="API Key" />
                            <ui:PasswordBox Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,0,0,8"
                                            Password="{Binding Config.ApiKey, Mode=TwoWay}"
                                            PlaceholderText="sk-..." />

                            <ui:TextBlock Grid.Row="2"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="模型" />
                            <ui:TextBox Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,0,8"
                                        Text="{Binding Config.Model, Mode=TwoWay}"
                                        PlaceholderText="gpt-4o-mini" />

                            <ui:TextBlock Grid.Row="3"
                                          Grid.Column="0"
                                          Margin="0,0,12,0"
                                          FontTypography="BodyStrong"
                                          Text="最大上下文(字符)" />
                            <ui:TextBox Grid.Row="3"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        Text="{Binding Config.MaxContextChars, Mode=TwoWay}"
                                        PlaceholderText="80000" />
                        </Grid>
                    </ui:CardExpander>

                    <ui:CardExpander IsExpanded="False"
                                     Margin="0,12,0,0"
                                     ContentPadding="12"
                                     Icon="{ui:SymbolIcon DataHistogram24}">
                        <ui:CardExpander.Header>
                            <StackPanel>
                                <ui:TextBlock FontTypography="BodyStrong" Text="向量模型（脚本检索）" />
                                <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                              Text="使用 OpenAI Embeddings 格式接口，对脚本名称进行语义检索与重排。" />
                            </StackPanel>
                        </ui:CardExpander.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <ui:TextBlock Grid.Row="0"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="启用向量检索" />
                            <ui:ToggleSwitch Grid.Row="0"
                                             Grid.Column="1"
                                             HorizontalAlignment="Left"
                                             IsChecked="{Binding Config.VectorSearchEnabled, Mode=TwoWay}" />

                            <ui:TextBlock Grid.Row="1"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="复用 AI 站点" />
                            <ui:ToggleSwitch Grid.Row="1"
                                             Grid.Column="1"
                                             HorizontalAlignment="Left"
                                             IsEnabled="{Binding Config.VectorSearchEnabled}"
                                             IsChecked="{Binding Config.VectorUseSameApiSite, Mode=TwoWay}" />

                            <ui:TextBlock Grid.Row="2"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="Base URL" />
                            <ui:TextBox Grid.Row="2"
                                        Grid.Column="1"
                                        Margin="0,0,0,8"
                                        IsEnabled="{Binding Config.VectorEndpointEditable}"
                                        Text="{Binding Config.VectorBaseUrl, Mode=TwoWay}"
                                        PlaceholderText="勾选“复用 AI 站点”时此项会被忽略" />

                            <ui:TextBlock Grid.Row="3"
                                          Grid.Column="0"
                                          Margin="0,0,12,8"
                                          FontTypography="BodyStrong"
                                          Text="API Key" />
                            <ui:PasswordBox Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="0,0,0,8"
                                            IsEnabled="{Binding Config.VectorEndpointEditable}"
                                            Password="{Binding Config.VectorApiKey, Mode=TwoWay}"
                                            PlaceholderText="勾选“复用 AI 站点”时此项会被忽略" />

                            <ui:TextBlock Grid.Row="4"
                                          Grid.Column="0"
                                          Margin="0,0,12,0"
                                          FontTypography="BodyStrong"
                                          Text="模型" />
                            <ui:TextBox Grid.Row="4"
                                        Grid.Column="1"
                                        Margin="0,0,0,0"
                                        IsEnabled="{Binding Config.VectorSearchEnabled}"
                                        Text="{Binding Config.VectorModel, Mode=TwoWay}"
                                        PlaceholderText="BAAI/bge-m3" />
                        </Grid>
                    </ui:CardExpander>

                    <ui:CardExpander IsExpanded="False"
                                     Margin="0,12,0,0"
                                     ContentPadding="12"
                                     Icon="{ui:SymbolIcon DeveloperBoard24}">
                        <ui:CardExpander.Header>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <ui:TextBlock FontTypography="BodyStrong" Text="MCP 工具调用" />
                                    <ui:TextBlock Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                                  Text="{Binding McpStatus}" />
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Margin="12,0,0,0"
                                           Command="{Binding RefreshMcpToolsCommand}"
                                           Content="刷新"
                                           Icon="{ui:SymbolIcon ArrowAutofitUp24}" />
                            </Grid>
                        </ui:CardExpander.Header>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Row="0"
                                      Grid.Column="0"
                                      Margin="0,0,8,8"
                                      ItemsSource="{Binding McpTools}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedMcpTool}" />
                            <ui:Button Grid.Row="0"
                                       Grid.Column="1"
                                       Margin="0,0,0,8"
                                       Command="{Binding CallMcpToolCommand}"
                                       Content="调用" />

                            <ui:TextBlock Grid.Row="1"
                                          Grid.ColumnSpan="2"
                                          Margin="0,0,0,6"
                                          Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                          Text="{Binding SelectedMcpTool.Description}" />

                            <ui:TextBox Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Margin="0,0,0,8"
                                        MinHeight="72"
                                        TextWrapping="Wrap"
                                        AcceptsReturn="True"
                                        Text="{Binding McpArguments, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="工具参数 JSON" />

                            <ui:TextBox Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        MinHeight="72"
                                        IsReadOnly="True"
                                        TextWrapping="Wrap"
                                        Text="{Binding SelectedMcpTool.InputSchema}"
                                        FontFamily="Consolas"
                                        Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}"
                                        PlaceholderText="参数结构" />
                        </Grid>
                    </ui:CardExpander>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1"
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <ui:Button Content="关闭"
                           Click="OnCloseClick" />
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
